# =============================================================================
# Orkestra Mesh — Environment Variables
# =============================================================================
# Copy this file to .env and edit as needed:
#   cp .env.example .env
#
# NOTE: When running with Docker Compose, most ORKESTRA_* variables are
# explicitly set in docker-compose.yml and do NOT read from this .env file.
# To override them in Docker, edit docker-compose.yml directly.
#
# The one variable that docker-compose.yml reads from .env (via ${VAR:-}
# substitution) is OPENAI_API_KEY — required by Obot.
# =============================================================================

# -----------------------------------------------------------------------------
# Required by Obot (MCP catalog server)
# docker-compose.yml passes this to the obot container via ${OPENAI_API_KEY:-}
# -----------------------------------------------------------------------------
OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# Database (change host/port for non-Docker local dev)
# -----------------------------------------------------------------------------
ORKESTRA_DATABASE_URL=postgresql+asyncpg://orkestra:orkestra@localhost:5434/orkestra
ORKESTRA_DATABASE_URL_SYNC=postgresql://orkestra:orkestra@localhost:5434/orkestra

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
ORKESTRA_REDIS_URL=redis://localhost:6382/0

# -----------------------------------------------------------------------------
# Security — MUST change before any non-localhost deployment
# -----------------------------------------------------------------------------
ORKESTRA_SECRET_KEY=orkestra-dev-secret-key-change-in-production
ORKESTRA_API_KEYS=test-orkestra-api-key
ORKESTRA_AUTH_ENABLED=false

# Fernet key for encrypting secrets in the database.
# If unset, an ephemeral key is generated at startup — secrets are lost on restart.
# Generate a stable key:
#   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ORKESTRA_FERNET_KEY=

# -----------------------------------------------------------------------------
# Obot integration
# -----------------------------------------------------------------------------
ORKESTRA_OBOT_BASE_URL=http://localhost:8080
ORKESTRA_OBOT_API_KEY=                    # clé API Obot (ok1-1-2-...)
ORKESTRA_OBOT_USE_MOCK=false
ORKESTRA_OBOT_FALLBACK_TO_MOCK=false

# -----------------------------------------------------------------------------
# LLM — Ollama (must run on the host machine, not in Docker)
# -----------------------------------------------------------------------------
ORKESTRA_LLM_PROVIDER=ollama
ORKESTRA_OLLAMA_HOST=http://localhost:11434
ORKESTRA_OLLAMA_MODEL=mistral

# -----------------------------------------------------------------------------
# LLM — OpenAI-compatible (alternative to Ollama)
# -----------------------------------------------------------------------------
ORKESTRA_OPENAI_API_KEY=
ORKESTRA_OPENAI_MODEL=mistral-small-latest
ORKESTRA_OPENAI_BASE_URL=https://api.mistral.ai/v1

# -----------------------------------------------------------------------------
# Observability
# -----------------------------------------------------------------------------
ORKESTRA_LOG_LEVEL=INFO
ORKESTRA_PROMETHEUS_ENABLED=false
ORKESTRA_OTEL_ENDPOINT=

# -----------------------------------------------------------------------------
# Debug
# -----------------------------------------------------------------------------
ORKESTRA_DEBUG=false
